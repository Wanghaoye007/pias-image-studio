server {
    listen 80;
    listen [::]:80;
    server_name studio.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name studio.example.com;

    ssl_certificate /etc/letsencrypt/live/studio.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/studio.example.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_session_timeout 1d;
    ssl_session_cache shared:PIAS_TLS:10m;
    ssl_session_tickets off;

    server_tokens off;
    client_header_timeout 15s;
    client_body_timeout 60s;
    keepalive_timeout 5s;
    client_header_buffer_size 8k;
    large_client_header_buffers 2 8k;
    client_max_body_size 1m;

    proxy_http_version 1.1;
    proxy_connect_timeout 5s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;
    proxy_request_buffering on;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header Origin $http_origin;
    proxy_set_header Sec-Fetch-Site $http_sec_fetch_site;
    error_page 413 = @body_too_large;

    location @body_too_large {
        default_type application/json;
        add_header Cache-Control "no-store" always;
        add_header X-Content-Type-Options "nosniff" always;
        return 413 '{"error":{"code":"REQUEST_BODY_TOO_LARGE","message":"请求内容超过反向代理限制"}}';
    }

    location ^~ /api/auth/ {
        client_max_body_size 8k;
        proxy_pass http://127.0.0.1:4173;
    }

    location ^~ /api/organization/ {
        client_max_body_size 16k;
        proxy_pass http://127.0.0.1:4173;
    }

    location = /api/studio/state {
        client_max_body_size 5m;
        proxy_pass http://127.0.0.1:4173;
    }

    location = /api/assets/images {
        client_max_body_size 10m;
        proxy_pass http://127.0.0.1:4173;
    }

    location = /api/fal/jobs {
        client_max_body_size 40m;
        proxy_pass http://127.0.0.1:4173;
    }

    location / {
        proxy_pass http://127.0.0.1:4173;
    }
}
